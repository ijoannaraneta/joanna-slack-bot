# Slack Configuration
# User OAuth token (xoxp-...) from your Slack app with these user scopes:
#   users.profile:write  (status sync)
#   dnd:write            (Do Not Disturb during focus/meetings)
#   dnd:read             (check current snooze state)
#   chat:write, im:write (daily agenda DM)
SLACK_USER_TOKEN=xoxp-your-slack-user-token

# Google Calendar Configuration
# OAuth client from Google Cloud Console (type: Web application,
# with http://localhost:3333/oauth2callback as an authorized redirect URI)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Generate with: npm run get-google-token
GOOGLE_REFRESH_TOKEN=your-refresh-token
GOOGLE_CALENDAR_ID=primary

# Timezone (IANA name) used for the daily agenda
TIMEZONE=Europe/London

# Security
# Any long random string, e.g. from: openssl rand -hex 32
# Required as "Authorization: Bearer <secret>" when calling /api/sync in production
CRON_SECRET=your-random-secret
